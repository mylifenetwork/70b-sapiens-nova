# Option A: use a single DATABASE_URL (recommended)
# Example:
# DATABASE_URL="mysql://root:password@127.0.0.1:3306/sapiens_nova"

# Option B: use discrete variables
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_USER=root
# DB_PASSWORD=password
# DB_NAME=sapiens_nova

# Optional
# DB_CONNECTION_LIMIT=10
# DB_SSL=false
# DB_SSL_REJECT_UNAUTHORIZED=true
# DB_SSL_CA_PATH=
# DB_SSL_CA_BASE64=
# DB_SSL_CERT_BASE64=
# DB_SSL_KEY_BASE64=
